# Copy to .env (gitignored) and fill in real values for local `docker compose up`.
# In production (Unraid), set these as container variables instead.

# Base URL of your Gramps Web instance (no trailing /api).
GRAMPS_API_URL=http://grampsweb:5000

# A dedicated READ-ONLY Gramps account (Guest/member role) the viewer
# auto-authenticates with at runtime. Do NOT use an admin account.
GRAMPS_VIEWER_USER=
GRAMPS_VIEWER_PASS=

# Header / browser-tab title.
VIEWER_TITLE=Family Tree
